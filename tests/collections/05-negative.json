{
  "info": {
    "_postman_id": "05-negative",
    "name": "05 — Negative Tests",
    "description": "Negative and error-handling tests. Tests that depend on backend validation accept both error and stub-success responses (stubs don't validate).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET /products without token → 401",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 401 — no auth', function () {",
              "    pm.response.to.have.status(401);",
              "});",
              "",
              "pm.test('Error body present', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('error');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": { "type": "noauth" },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/products",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "products"]
        }
      }
    },
