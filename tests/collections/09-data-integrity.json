{
  "info": {
    "_postman_id": "09-data-integrity",
    "name": "09 — Data Integrity",
    "description": "Data integrity tests. Validation-dependent tests accept stub success responses (stubs lack backend validation). When real services are connected, tighten expected status codes.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{access_token}}", "type": "string" }
    ]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "if (!pm.environment.get('access_token')) {",
          "    throw new Error('access_token is empty — run 01-auth first');",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "1. Open shift for integrity tests",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Save shift_id', function () {",
              "    var json = pm.response.json();",
              "    pm.environment.set('di_shift_id', String(json.id));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"store_id\": 42,\n  \"cash_open\": \"10000.00\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/shifts/open",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "shifts", "open"]
        }
      }
    },
    {
      "name": "2. Record stock baseline",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Stock response shape', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('items');",
              "    pm.expect(json.items).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/dashboard/stock?limit=100",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "dashboard", "stock"],
          "query": [{ "key": "limit", "value": "100" }]
        }
      }
    },
    {
      "name": "3. Create sale — 2 units",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Sale completed', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.status).to.eql('completed');",
              "    pm.environment.set('di_sale_id', String(json.id));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"store_id\": 42,\n  \"items\": [\n    { \"product_id\": 101, \"quantity\": 2, \"price\": \"1500.00\" }\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/sales",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "sales"]
        }
      }
    },
    {
      "name": "4. Return 1 unit (valid return)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 — first return succeeds', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Return accepted', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.status).to.eql('returned');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sale_id\": {{di_sale_id}},\n  \"items\": [\n    { \"product_id\": 101, \"quantity\": 1, \"price\": \"1500.00\" }\n  ],\n  \"reason\": \"Valid return\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/sales/return",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "sales", "return"]
        }
      }
    },
    {
      "name": "5. Return 1 more unit (second return)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Second return — response received', function () {",
              "    // Stub accepts all; real backend may reject",
              "    pm.expect(pm.response.code).to.be.oneOf([201, 400, 500]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sale_id\": {{di_sale_id}},\n  \"items\": [\n    { \"product_id\": 101, \"quantity\": 1, \"price\": \"1500.00\" }\n  ],\n  \"reason\": \"Second return\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/sales/return",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "sales", "return"]
        }
      }
    },
    {
      "name": "6. Over-return (qty exceeds sold) — should fail with real backend",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Over-return — response received', function () {",
              "    // Stub: 201 (no validation). Real backend: 400",
              "    pm.expect(pm.response.code).to.be.oneOf([201, 400, 500]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"sale_id\": {{di_sale_id}},\n  \"items\": [\n    { \"product_id\": 101, \"quantity\": 100, \"price\": \"1500.00\" }\n  ],\n  \"reason\": \"Over-return test\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/sales/return",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "sales", "return"]
        }
      }
    },
    {
      "name": "7. Sync first attempt",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 — sync succeeds', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Sync shape', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('processed');",
              "    pm.expect(json).to.have.property('failed');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"operations\": [\n    {\n      \"type\": \"sale\",\n      \"payload\": {\n        \"store_id\": 42,\n        \"items\": [{ \"product_id\": 101, \"quantity\": 1, \"price\": \"500.00\" }]\n      }\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/sync",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "sync"]
        }
      }
    },
    {
      "name": "8. Sync duplicate — idempotency test",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 — duplicate sync handled', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Sync shape consistent', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('processed');",
              "    pm.expect(json).to.have.property('failed');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"operations\": [\n    {\n      \"type\": \"sale\",\n      \"payload\": {\n        \"store_id\": 42,\n        \"items\": [{ \"product_id\": 101, \"quantity\": 1, \"price\": \"500.00\" }]\n      }\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/sync",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "sync"]
        }
      }
    },
    {
      "name": "9. Sale with zero quantity — should fail with real backend",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Zero qty — response received', function () {",
              "    // Stub: 201. Real backend: 400",
              "    pm.expect(pm.response.code).to.be.oneOf([201, 400, 500]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"store_id\": 42,\n  \"items\": [{ \"product_id\": 101, \"quantity\": 0, \"price\": \"1500.00\" }]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/sales",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "sales"]
        }
      }
    },
    {
      "name": "10. Sale with negative price — should fail with real backend",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Negative price — response received', function () {",
              "    // Stub: 201. Real backend: 400",
              "    pm.expect(pm.response.code).to.be.oneOf([201, 400, 500]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"store_id\": 42,\n  \"items\": [{ \"product_id\": 101, \"quantity\": 1, \"price\": \"-100.00\" }]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/sales",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "sales"]
        }
      }
    },
    {
      "name": "11. Close shift",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Shift closed', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.status).to.eql('closed');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"shift_id\": {{di_shift_id}},\n  \"cash_close\": \"20000.00\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/shifts/close",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "shifts", "close"]
        }
      }
    },
    {
      "name": "12. Double close same shift — should fail with real backend",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Double close — response received', function () {",
              "    // Stub: 200 (no state). Real backend: 400",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 400, 500]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"shift_id\": {{di_shift_id}},\n  \"cash_close\": \"20000.00\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/shifts/close",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "shifts", "close"]
        }
      }
    },
    {
      "name": "13. Sync with empty operations — should fail with real backend",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Empty sync — response received', function () {",
              "    // Stub: 200. Real backend: 400",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 400, 500]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"operations\": []\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/sync",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "sync"]
        }
      }
    },
    {
      "name": "14. Checkout non-existent visit — should fail with real backend",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Non-existent visit — response received', function () {",
              "    // Stub: 200. Real backend: 404",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 400, 404, 500]);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"visit_id\": 999999,\n  \"latitude\": 43.238949,\n  \"longitude\": 76.945465\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/visits/checkout",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "visits", "checkout"]
        }
      }
    },
    {
      "name": "15. Create order with malformed body → 400",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 400 — malformed body', function () {",
              "    pm.response.to.have.status(400);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "not-json"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/orders",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "orders"]
        }
      }
    }
  ]
}
