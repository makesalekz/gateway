{
  "info": {
    "_postman_id": "08-rbac",
    "name": "08 — RBAC Access Control",
    "description": "Role-based access: cashier can sell but not billing, owner can dashboard but not checkin, agent can order but not open shift.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "exec": [
          "// All RBAC tests require access_token from 01-auth",
          "if (!pm.environment.get('access_token')) {",
          "    throw new Error('access_token is empty — run 01-auth first');",
          "}"
        ],
        "type": "text/javascript"
      }
    }
  ],
  "item": [
    {
      "name": "Cashier — can list products",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 — cashier can list products', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Products returned', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json).to.have.property('items');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/products?limit=5",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "products"],
          "query": [{ "key": "limit", "value": "5" }]
        }
      }
    },
    {
      "name": "Cashier — can search products",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200 — cashier can search', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/products/search?q=coca&limit=5",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "products", "search"],
          "query": [
            { "key": "q", "value": "coca" },
            { "key": "limit", "value": "5" }
          ]
        }
      }
    },
    {
      "name": "Cashier — can open shift",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 — cashier can open shift', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Save shift for closing', function () {",
              "    var json = pm.response.json();",
              "    pm.environment.set('rbac_shift_id', String(json.id));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
        },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"store_id\": 42,\n  \"cash_open\": \"5000.00\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/shifts/open",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "shifts", "open"]
        }
      }
    },
    {
      "name": "Cashier — can create sale",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 201 — cashier can sell', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Sale completed', function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.status).to.eql('completed');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
        },
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"store_id\": 42,\n  \"items\": [\n    { \"product_id\": 101, \"quantity\": 1, \"price\": \"350.00\" }\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/sales",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "sales"]
        }
      }
    },
    {
      "name": "Cashier — close shift",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
